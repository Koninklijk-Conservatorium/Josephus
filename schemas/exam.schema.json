{
  "$id": "josephus-exam-spec",
  "$ref": "#/definitions/ExamSpec",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ChallengeSpec": {
      "additionalProperties": false,
      "properties": {
        "tasks": {
          "items": {
            "$ref": "#/definitions/TaskSpec"
          },
          "type": "array"
        }
      },
      "required": [
        "tasks"
      ],
      "type": "object"
    },
    "ExamSpec": {
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "challenges": {
          "items": {
            "$ref": "#/definitions/ChallengeSpec"
          },
          "type": "array"
        }
      },
      "required": [
        "$schema",
        "challenges"
      ],
      "type": "object"
    },
    "FieldSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "events": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "extractor": {
          "$ref": "#/definitions/ScoreExtractor"
        },
        "filter": {
          "items": {
            "$ref": "#/definitions/ScoreFeature"
          },
          "type": "array"
        },
        "gui": {
          "$ref": "#/definitions/JosephusGUI"
        },
        "items": {
          "type": "number"
        },
        "layout": {
          "$ref": "#/definitions/ScoreLayout"
        },
        "repr": {
          "items": {
            "$ref": "#/definitions/ScoreRepr"
          },
          "type": "array"
        },
        "scoreRefs": {
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        "type": {
          "$ref": "#/definitions/FieldType"
        }
      },
      "required": [
        "type",
        "scoreRefs",
        "filter",
        "repr",
        "gui",
        "items",
        "description"
      ],
      "type": "object"
    },
    "FieldType": {
      "enum": [
        "legend",
        "question",
        "answer"
      ],
      "type": "string"
    },
    "JosephusGUI": {
      "enum": [
        "display",
        "quiz",
        "connect",
        "order",
        "selection"
      ],
      "type": "string"
    },
    "ScoreExtractor": {
      "enum": [
        "pitches",
        "segments",
        "chordsWithFermata"
      ],
      "type": "string"
    },
    "ScoreFeature": {
      "enum": [
        "pitches",
        "durations",
        "accidentals",
        "articulations"
      ],
      "type": "string"
    },
    "ScoreLayout": {
      "enum": [
        "full",
        "piano-staff",
        "single-staff"
      ],
      "type": "string"
    },
    "ScoreRepr": {
      "enum": [
        "score",
        "audio",
        "label"
      ],
      "type": "string"
    },
    "ScoreSpec": {
      "additionalProperties": false,
      "properties": {
        "entity": {
          "const": "score",
          "type": "string"
        },
        "fileName": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "source",
        "entity"
      ],
      "type": "object"
    },
    "TaskSpec": {
      "additionalProperties": false,
      "properties": {
        "fields": {
          "items": {
            "$ref": "#/definitions/FieldSpec"
          },
          "type": "array"
        },
        "scores": {
          "items": {
            "$ref": "#/definitions/ScoreSpec"
          },
          "type": "array"
        }
      },
      "required": [
        "scores",
        "fields"
      ],
      "type": "object"
    }
  }
}